FROM node:22-alpine

WORKDIR /app

# Instalar dependencias necesarias para node-gyp u otras librerías nativas si fuera necesario
RUN apk add --no-cache libc6-compat

# Deshabilitar telemetría de Next.js
ENV NEXT_TELEMETRY_DISABLED 1

# Exponer el puerto de la aplicación y el puerto de depuración (Node Inspector)
EXPOSE 3000
EXPOSE 9229

# En desarrollo, solemos montar el volumen, pero instalamos dependencias primero
# para que el contenedor sea funcional de inmediato.
COPY package.json package-lock.json* ./
RUN npm install

# Copiar el resto del código (será sobrescrito por el volumen en docker-compose)
COPY . .

# Comando para iniciar en modo desarrollo con soporte para debugger
# Nota: "next dev" no soporta --inspect directamente de forma fácil en versiones antiguas,
# pero en las nuevas se puede pasar vía NODE_OPTIONS.
ENV NODE_OPTIONS='--inspect=0.0.0.0:9229'

CMD ["npm", "run", "dev"]
